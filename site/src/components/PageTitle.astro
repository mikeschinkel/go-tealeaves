---
const PAGE_TITLE_ID = '_top';

const iconMap: Record<string, string> = {
  'confirm-dialog': '/go-tealeaves/icons/icon-teamodal.svg',
  'choice-dialog': '/go-tealeaves/icons/icon-teamodal.svg',
  'list-dialog': '/go-tealeaves/icons/icon-teamodal.svg',
  'progress-dialog': '/go-tealeaves/icons/icon-teamodal.svg',
  'multiselect-dialog': '/go-tealeaves/icons/icon-teamodal.svg',
  'dropdown-control': '/go-tealeaves/icons/icon-teafields.svg',
  'grid-view': '/go-tealeaves/icons/icon-teagrid.svg',
  'tree-view': '/go-tealeaves/icons/icon-teatree.svg',
  'drilldown-view': '/go-tealeaves/icons/icon-teatree.svg',
  'breadcrumb-nav': '/go-tealeaves/icons/icon-teacrumbs.svg',
  'statusbar-view': '/go-tealeaves/icons/icon-teastatus.svg',
  'notification-view': '/go-tealeaves/icons/icon-teanotify.svg',
  'help-visor': '/go-tealeaves/icons/icon-teahelp.svg',
  'diff-viewer': '/go-tealeaves/icons/icon-teadiff.svg',
  'layout-engine': '/go-tealeaves/icons/icon-tealayout.svg',
  'guide-overlay': '/go-tealeaves/icons/icon-teaguide.svg',
  'text-selection': '/go-tealeaves/icons/icon-teatext.svg',
  'syntax-highlighting': '/go-tealeaves/icons/icon-hilite.svg',
  'key-registry': '/go-tealeaves/icons/icon-keyregistry.svg',
  'theming': '/go-tealeaves/icons/icon-theming.svg',
  'positioning': '/go-tealeaves/icons/icon-positioning.svg',
  'pane-widgets': '/go-tealeaves/icons/icon-teapane.svg',
  'color-constants': '/go-tealeaves/icons/icon-teacolor.svg',
};

const route = Astro.locals.starlightRoute;
const title = route.entry.data.title;
const entryId = route.entry.id ?? route.id ?? '';
const lastSegment = entryId.split('/').pop()?.replace(/\.mdx?$/, '') ?? '';
const iconSrc = iconMap[lastSegment];

// Split "teagrid — Data Grid" into name + subtitle
const titleParts = title.split(' — ');
const hasSubtitle = iconSrc && titleParts.length === 2;
const mainTitle = hasSubtitle ? titleParts[0] : title;
const subtitle = hasSubtitle ? `${titleParts[1]} Component` : '';
---

{iconSrc ? (
  <div class="page-title-with-icon">
    <img src={iconSrc} alt="" class="page-title-icon" />
    <div class="page-title-text">
      <h1 id={PAGE_TITLE_ID}>{mainTitle}</h1>
      {subtitle && <span class="page-title-subtitle">{subtitle}</span>}
    </div>
  </div>
) : (
  <h1 id={PAGE_TITLE_ID}>{title}</h1>
)}

<style>
  @layer starlight.components {
    .page-title-with-icon {
      display: flex;
      align-items: center;
      gap: 1rem;
    }
    .page-title-icon {
      width: 56px;
      height: 56px;
      flex-shrink: 0;
      background: #0f172a;
      border-radius: 8px;
      padding: 8px;
    }
    .page-title-text {
      display: flex;
      flex-direction: column;
    }
    h1 {
      margin-top: 1rem;
      font-size: var(--sl-text-h1);
      line-height: var(--sl-line-height-headings);
      font-weight: 600;
      color: var(--sl-color-white);
    }
    .page-title-with-icon h1 {
      margin-top: 0;
    }
    .page-title-subtitle {
      font-size: 1.1rem;
      font-weight: 500;
      color: #059669;
      margin-top: 0.15rem;
    }
  }
</style>
