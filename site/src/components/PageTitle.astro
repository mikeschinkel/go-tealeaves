---
const PAGE_TITLE_ID = '_top';

const iconMap: Record<string, string> = {
  'teadd': '/go-tealeaves/icons/icon-teadd.svg',
  'teagrid': '/go-tealeaves/icons/icon-teagrid.svg',
  'teamodal': '/go-tealeaves/icons/icon-teamodal.svg',
  'teanotify': '/go-tealeaves/icons/icon-teanotify.svg',
  'teatree': '/go-tealeaves/icons/icon-teatree.svg',
  'teatextsel': '/go-tealeaves/icons/icon-teatextsel.svg',
  'teastatus': '/go-tealeaves/icons/icon-teastatus.svg',
  'teadep': '/go-tealeaves/icons/icon-teadep.svg',
  'teautils': '/go-tealeaves/icons/icon-teautils.svg',
};

const route = Astro.locals.starlightRoute;
const title = route.entry.data.title;
const entryId = route.entry.id ?? route.id ?? '';
const lastSegment = entryId.split('/').pop()?.replace(/\.mdx?$/, '') ?? '';
const iconSrc = iconMap[lastSegment];
---

{iconSrc ? (
  <div class="page-title-with-icon">
    <img src={iconSrc} alt="" class="page-title-icon" />
    <h1 id={PAGE_TITLE_ID}>{title}</h1>
  </div>
) : (
  <h1 id={PAGE_TITLE_ID}>{title}</h1>
)}

<style>
  @layer starlight.components {
    .page-title-with-icon {
      display: flex;
      align-items: center;
      gap: 1rem;
    }
    .page-title-icon {
      width: 48px;
      height: 48px;
      flex-shrink: 0;
    }
    h1 {
      margin-top: 1rem;
      font-size: var(--sl-text-h1);
      line-height: var(--sl-line-height-headings);
      font-weight: 600;
      color: var(--sl-color-white);
    }
    .page-title-with-icon h1 {
      margin-top: 0;
    }
  }
</style>
